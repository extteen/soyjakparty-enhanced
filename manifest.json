{
  "manifest_version": 3,
  "name": "Soyjak Party Enhanced",
  "version": "4.0.0",
  "description": "Enhances the Soyjak.Party experience or something",
  "permissions": [
    "storage",
    "scripting",
    "activeTab",
    "tabs"
  ],
  "host_permissions": [
    "*://soybooru.com/*",
    "*://*.soyjak.st/*",
    "*://*.soyjak.party/*",
    "*://soyjakwiki.org/*"
  ],
  "action": {
    "default_icon": {
      "32": "icons/spe-32.png",
      "48": "icons/spe-64.png",
      "64": "icons/spe-64.png",
      "128": "icons/spe-64.png"
    }
  },
  "icons": {
   "32": "icons/spe-32.png",
   "48": "icons/spe-64.png",
   "64": "icons/spe-64.png",
   "128": "icons/spe-64.png"
  },
  "web_accessible_resources": [
    {
      "resources": [
        "icons/*",
        "audio/*",
        "settings.html",
        "settings.js"
      ],
      "matches": ["<all_urls>"]
    }
  ],
  "content_scripts": [
    {
      "matches": [
        "*://*.soyjak.party/*",
        "*://*.soyjak.st/*",
        "*://soybooru.com/*",
        "*://soyjakwiki.org/*"
      ],
      "js": [
        "browser-polyfill.min.js",
        "main-functions.js",
        "text-post-formatting.js"
      ],
      "run_at": "document_end"
    }
  ],
  "browser_specific_settings": {
    "gecko": {
      "id": "addon@example.com",
      "strict_min_version": "102.0"
    }
  }
}
